region             = "us-west-2"
cluster_name       = "k8s-dev"
kubernetes_version = "1.35"
vpc_cidr           = "10.0.0.0/16"

availability_zones = [
  "us-west-2a",
  "us-west-2b",
  "us-west-2c",
]

public_access_cidrs = ["0.0.0.0/0"]

# CPU-first defaults
enable_gpu_node_group = false
gpu_az                = "us-west-2a"
gpu_machine_type      = "g4dn.xlarge"
gpu_node_label_key    = "accelerator"
gpu_node_label_value  = "gpu-t4"
gpu_ami_type          = "AL2023_x86_64_NVIDIA"
gpu_desired_nodes     = 0
gpu_min_nodes         = 0
gpu_max_nodes         = 4

# Optional test preset:
# gpu_machine_type     = "g4dn.xlarge"
# gpu_node_label_value = "gpu-t4"
# gpu_desired_nodes    = 2
# gpu_min_nodes        = 2
# kueue_gpu_quota      = 2

cpu_worker_machine_type = "m5.4xlarge"
cpu_worker_ami_type     = "AL2023_x86_64_STANDARD"
cpu_worker_desired_nodes = 0
cpu_worker_min_nodes     = 0
cpu_worker_max_nodes     = 8

system_machine_type = "m5.xlarge"
system_ami_type     = "AL2023_x86_64_STANDARD"
system_desired_nodes = 1
system_min_nodes     = 1
system_max_nodes     = 2

enable_head_node_group = false
head_machine_type = "m5.2xlarge"
head_ami_type     = "AL2023_x86_64_STANDARD"
head_desired_nodes = 0
head_min_nodes     = 0
head_max_nodes     = 2

# Optional components
enable_kuberay = false

# -----------------------------------------------------------------------------
# Infra-only preset: multi-node KubeRay + RayCluster demo profile (commented)
# - Keeps app/workload logic out of infra defaults
# - Uncomment to enable a CPU-only multi-node Ray cluster baseline
# - Reset any temporary non-zero cpu/gpu/head counts back to 0 after demos to avoid orphaned compute
# -----------------------------------------------------------------------------
# enable_kuberay                  = true
# enable_ray_cluster              = true
# enable_head_node_group          = true
# cpu_worker_desired_nodes        = 2
# cpu_worker_min_nodes            = 2
# ray_cluster_cpu_worker_replicas = 2
# ray_cluster_queue_name          = "default-queue"
#
# Optional GPU RayCluster overrides (only if enabling GPU workers)
# gpu_machine_type                  = "g4dn.xlarge"
# gpu_node_label_value              = "gpu-t4"
# ray_cluster_gpu_worker_replicas    = 1
# ray_cluster_gpu_worker_cpu         = "8"
# ray_cluster_gpu_worker_memory      = "32Gi"
# ray_cluster_gpu_worker_gpu_count   = 1
# ray_cluster_gpu_worker_label_key   = "accelerator"
# ray_cluster_gpu_worker_label_value = "gpu-t4"
#
# Optional CPU worker label overrides (only if your CPU node group labels differ)
# Ensure overrides exactly match labels on the actual CPU worker node group.
# ray_cluster_cpu_worker_label_key   = "role"
# ray_cluster_cpu_worker_label_value = "cpu-worker"

# Kueue queue defaults
kueue_namespace             = "kueue-system"
kueue_local_queue_namespace = "default"
kueue_local_queue_name      = "default-queue"
kueue_cluster_queue_name    = "default-cluster-queue"
kueue_gpu_quota             = 0
